{
  "schema_version": "0.1-local",
  "description": "endpoint-ci local detection rules. Two layers: 'detectors' (atomic leaf data types with RE2-safe patterns + validators) and 'profiles' (named concepts composed from detectors). Authored by us \u2014 the cloud policy export contains no patterns. Patterns are Go regexp (RE2): NO lookahead/lookbehind/backreference.",
  "confidence_model": {
    "_doc": "Per detector: start at base_confidence. Boost +validator_boost if a validator passes, +keyword_boost if a context keyword is within keyword_window chars of the match, +instance_boost per extra match up to max_instance_boosts. Cap 100. A detector 'fires' at/above its fire_threshold.",
    "validator_boost": 10,
    "keyword_boost": 5,
    "instance_boost": 5,
    "max_instance_boosts": 3,
    "keyword_window": 200,
    "default_fire_threshold": 50,
    "block_threshold": 65,
    "early_exit": {
      "enabled": true,
      "stop_on_block": true,
      "max_total_matches": 1000
    }
  },
  "validators": {
    "luhn_check": "Luhn mod-10 (strip non-digits first)",
    "iban_mod97": "IBAN ISO 7064 mod-97-10 + country length table",
    "aba_checksum": "ABA routing 3-7-1 weighted mod-10",
    "vin_check": "ISO 3779 VIN check digit (position 9)",
    "ssn_check": "US SSN range rules: area not 000/666/900-999, group not 00, serial not 0000",
    "ein_prefix": "US EIN valid IRS campus prefix table",
    "npi_check": "US NPI Luhn over '80840' + 9 digits",
    "dea_check": "US DEA: (d1+d3+d5) + 2*(d2+d4+d6) mod 10 == d7",
    "itin_check": "US ITIN: leads with 9, group digits in 50-65/70-88/90-92/94-99",
    "sin_check": "Canada SIN / 9-digit Luhn",
    "nir_check": "France NIR: 15 digits, key = 97 - (first13 mod 97)",
    "de_tax_check": "Germany tax IdNr: 11 digits, ISO 7064 MOD 11,10",
    "es_dni_check": "Spain DNI: 8 digits + letter (table[n mod 23])",
    "bsn_check": "Netherlands BSN: 9-digit weighted 11-test"
  },
  "detectors": [
    {
      "id": "credit_card",
      "name": "Credit / Debit Card Number",
      "group": "financial",
      "data_types": [
        "DT_Financial_PCI",
        "DT_PII_Personal_Data"
      ],
      "patterns": [
        "\\b(?:4[0-9]{12}(?:[0-9]{3})?|5[1-5][0-9]{14}|3[47][0-9]{13}|3(?:0[0-5]|[68][0-9])[0-9]{11}|6(?:011|5[0-9]{2})[0-9]{12})\\b"
      ],
      "validators": [
        "luhn_check"
      ],
      "keywords": [
        "card",
        "visa",
        "mastercard",
        "amex",
        "discover",
        "payment",
        "cc",
        "credit"
      ],
      "base_confidence": 60,
      "notes": "Major-network contiguous digits. Luhn kills most FPs.",
      "prefilter": {
        "needs_digit": true
      }
    },
